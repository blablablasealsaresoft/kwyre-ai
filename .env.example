# ┌──────────────────────────────────────────────────────────────────────────────┐
# │  Kwyre AI — Environment Configuration (v1.1)                              │
# │  Copy this file to .env and edit the values.                               │
# │     cp .env.example .env                                                   │
# └──────────────────────────────────────────────────────────────────────────────┘

# ── Authentication ────────────────────────────────────────────────────────────
# API keys for server access. Format: key:role (comma-separated for multiple)
# Roles: admin, analyst, viewer
KWYRE_API_KEYS=sk-kwyre-dev-local:admin

# ── Model Settings ────────────────────────────────────────────────────────────
# Model tier to serve:
#   Personal:     Qwen/Qwen3.5-4B  (~3.9 GB VRAM, 7-14 tok/s, $299)
#   Professional: Qwen/Qwen3.5-9B  (~7.5 GB VRAM, 3-5 tok/s, $799)
# Both tiers use the same Qwen3.5-0.8B draft model for speculative decoding.
KWYRE_MODEL=HauhauCS/Qwen3.5-4B-Uncensored-HauhauCS-Aggressive

# Quantization mode: nf4 (default, BitsAndBytes) | awq (1.4x faster)
KWYRE_QUANT=nf4

# Enable speculative decoding with draft model (1=enabled, 0=disabled)
KWYRE_SPECULATIVE=1

# Draft model for speculative decoding
# KWYRE_DRAFT_MODEL=Qwen/Qwen3.5-0.8B

# Merge LoRA adapters into base model at load time
KWYRE_MERGE_LORA=0

# Domain Adapter System
KWYRE_ADAPTER_DIR=~/.kwyre/adapters
# KWYRE_DEFAULT_ADAPTER=legal_compliance
KWYRE_ALLOW_ADAPTER_SWAP=1
# KWYRE_ADAPTER_MANIFEST_URL=https://kwyre.com/adapters/manifest.json

# ── Backend Selection ─────────────────────────────────────────────────────────
# Inference backend: gpu (default) | cpu | mlx | vllm
# KWYRE_BACKEND=gpu

# ── Paths ─────────────────────────────────────────────────────────────────────
# HuggingFace cache directory (model weights stored here)
HF_CACHE=./.cache/huggingface

# Path to pre-quantized model (overrides HuggingFace cache lookup)
# Personal:     KWYRE_MODEL_PATH=./dist/kwyre-4b-nf4
# Professional: KWYRE_MODEL_PATH=./dist/kwyre-9b-nf4
# KWYRE_MODEL_PATH=./dist/kwyre-4b-nf4

# Path to pre-quantized draft model
# KWYRE_DRAFT_PATH=./dist/kwyre-draft-nf4

# Path to AWQ pre-quantized model
# Personal:     KWYRE_AWQ_MODEL_PATH=./models/kwyre-4b-awq
# Professional: KWYRE_AWQ_MODEL_PATH=./models/kwyre-9b-awq
# KWYRE_AWQ_MODEL_PATH=./models/kwyre-4b-awq

# Path to QAT / LoRA adapter directory
QAT_PATH=./qat_output_v1/final

# Path to GGUF model for CPU mode
# Personal:     KWYRE_GGUF_PATH=./models/kwyre-4b.gguf
# Professional: KWYRE_GGUF_PATH=./models/kwyre-9b.gguf
# KWYRE_GGUF_PATH=./models/kwyre-4b.gguf

# ── GPU ───────────────────────────────────────────────────────────────────────
NVIDIA_VISIBLE_DEVICES=0

# ── Network ───────────────────────────────────────────────────────────────────
# Bind address (127.0.0.1 for local, 0.0.0.0 for Docker containers)
# KWYRE_BIND_HOST=127.0.0.1

# Server port
# KWYRE_PORT=8000

# ── vLLM Settings (KWYRE_BACKEND=vllm only) ──────────────────────────────────
# GPU memory fraction to allocate
# KWYRE_VLLM_GPU_MEMORY=0.85

# Maximum context length
# KWYRE_VLLM_MAX_MODEL_LEN=8192

# Tensor parallel size (for multi-GPU)
# KWYRE_VLLM_TENSOR_PARALLEL=1

# ── RAG Document Ingestion ────────────────────────────────────────────────────
# Embedding model for document search (runs on CPU)
# KWYRE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Chunk size in characters for document splitting
# KWYRE_RAG_CHUNK_SIZE=1500

# Overlap between chunks
# KWYRE_RAG_CHUNK_OVERLAP=200

# Number of chunks to retrieve per query
# KWYRE_RAG_TOP_K=5

# ── Multi-User Mode ──────────────────────────────────────────────────────────
# Enable multi-user mode with RBAC (1=enabled, 0=disabled)
KWYRE_MULTI_USER=0

# Fernet encryption key for users file (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
# KWYRE_MASTER_KEY=

# Path to encrypted users file
# KWYRE_USERS_FILE=users.json

# Default max concurrent sessions per user
# KWYRE_MAX_SESSIONS_PER_USER=5

# Default rate limit (requests per minute) per user
# KWYRE_DEFAULT_RPM=30

# ── KV Cache ──────────────────────────────────────────────────────────────────
# Max sessions with cached KV state
# KWYRE_KV_CACHE_MAX=8

# VRAM budget for KV cache (GB)
# KWYRE_KV_CACHE_VRAM_GB=2.0

# ── Security ──────────────────────────────────────────────────────────────────
# Enable external API tools (BREAKS AIR-GAP — use only for testing)
KWYRE_ENABLE_TOOLS=0

# Skip dependency integrity check at startup
# KWYRE_SKIP_DEP_CHECK=0

# Disable torch.compile (avoids dynamo issues in inference)
TORCHDYNAMO_DISABLE=1

# ── Licensing ─────────────────────────────────────────────────────────────────
# Commercial license key (leave blank for evaluation mode)
KWYRE_LICENSE_KEY=

# License key file path
# KWYRE_LICENSE_FILE=/dev/null
