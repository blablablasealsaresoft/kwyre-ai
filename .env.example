# ┌──────────────────────────────────────────────────────────────────────────────┐
# │  Kwyre AI — Environment Configuration                                      │
# │  Copy this file to .env and edit the values.                               │
# │     cp .env.example .env                                                   │
# └──────────────────────────────────────────────────────────────────────────────┘

# ── Authentication ────────────────────────────────────────────────────────────
# API keys for server access. Format: key:role (semicolon-separated for multiple)
# Example: sk-prod-abc123:admin;sk-read-xyz:viewer
KWYRE_API_KEYS=sk-kwyre-dev-local:admin

# ── Model Settings ────────────────────────────────────────────────────────────
# HuggingFace model ID to serve
KWYRE_MODEL=Qwen/Qwen3.5-9B

# Quantization mode: nf4 (default, BitsAndBytes) | awq (1.4x faster, requires pre-quantization)
KWYRE_QUANT=nf4

# Enable speculative decoding with Qwen3-0.6B draft model (1=enabled, 0=disabled)
KWYRE_SPECULATIVE=1

# Merge LoRA adapters into base model at load time (1=merge, 0=in-place — use 0 on <24GB VRAM)
KWYRE_MERGE_LORA=0

# ── Paths ─────────────────────────────────────────────────────────────────────
# HuggingFace cache directory (model weights are stored here)
#   Linux default:   ~/.cache/huggingface
#   Windows example: C:\Users\YOU\.cache\huggingface
HF_CACHE=./.cache/huggingface

# Path to QAT / LoRA adapter directory (leave default if unused)
QAT_PATH=./qat_output_v1/final

# ── GPU ───────────────────────────────────────────────────────────────────────
# Comma-separated GPU device IDs (e.g. "0" or "0,1")
NVIDIA_VISIBLE_DEVICES=0

# ── Licensing ─────────────────────────────────────────────────────────────────
# Commercial license key (leave blank for evaluation)
KWYRE_LICENSE_KEY=

# Path to license key file on the host (mounted read-only into the container)
KWYRE_LICENSE_FILE=/dev/null
